.hero-card {
  background: linear-gradient(135deg, rgba(255, 248, 239, 0.96), rgba(250, 238, 221, 0.88));
}

.hero-title {
  margin-top: 18rpx;
  font-size: 56rpx;
  line-height: 1.05;
  font-weight: 900;
}

.hero-desc,
.hero-meta {
  margin-top: 16rpx;
  line-height: 1.75;
  font-size: 28rpx;
}

.hero-actions {
  margin-top: 20rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 20rpx -8rpx 0;
}

.stat-card {
  width: calc(50% - 16rpx);
  margin: 0 8rpx 16rpx;
}

.feed-list,
.topic-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.feed-card,
.topic-card {
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fffaf5;
  border: 1rpx solid rgba(117, 68, 37, 0.1);
}

.stat-label,
.feed-original,
.feed-source,
.topic-meta {
  color: #5f564b;
  font-size: 24rpx;
}

.stat-value {
  margin-top: 12rpx;
  font-size: 40rpx;
  font-weight: 800;
}

.feed-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.feed-title,
.topic-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 800;
}

.feed-summary,
.feed-angle,
.feed-pro,
.topic-angle {
  margin-top: 12rpx;
  line-height: 1.75;
  font-size: 26rpx;
}

.feed-angle,
.feed-pro {
  padding: 16rpx;
  border-radius: 18rpx;
}

.feed-angle {
  background: rgba(13, 122, 109, 0.08);
  color: #1d5c54;
}

.feed-pro {
  background: rgba(216, 106, 30, 0.08);
  color: #7b3f18;
}

.feed-link {
  margin-top: 14rpx;
  color: #8f3512;
  font-size: 24rpx;
  font-weight: 700;
}
